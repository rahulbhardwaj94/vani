# Vani environment overrides — all optional, sensible defaults built in.
# Copy to .env and edit. GUI launches (open build/Vani.app) use macOS's
# environment; these are picked up when running from a terminal:
#
#   set -a; source .env; set +a
#   swift run Vani          # or: open build/Vani.app (inherits shell env)

# Ollama server used for the optional LLM cleanup pass.
VANI_OLLAMA_URL=http://localhost:11434

# Seconds to wait for the LLM before silently falling back to rule-based cleanup.
VANI_OLLAMA_TIMEOUT=6
