# LokVaani environment overrides — all optional, sensible defaults built in.
# Copy to .env and edit. GUI launches (open build/LokVaani.app) use macOS's
# environment; these are picked up when running from a terminal:
#
#   set -a; source .env; set +a
#   swift run LokVaani          # or: open build/LokVaani.app (inherits shell env)

# Ollama server used for the optional LLM cleanup pass.
LOKVAANI_OLLAMA_URL=http://localhost:11434

# Seconds to wait for the LLM before silently falling back to rule-based cleanup.
LOKVAANI_OLLAMA_TIMEOUT=6
